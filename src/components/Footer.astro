---
const year = new Date().getFullYear();
---

<footer class="bg-forest text-cream mt-16">
  <div class="max-w-5xl mx-auto px-6 py-12">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">

      <!-- Brand -->
      <div>
        <div class="mb-3">
          <img src="/logo.svg" alt="A Green Family" class="h-10 w-auto brightness-0 invert opacity-90" />
        </div>
        <p class="text-sm text-sage leading-relaxed">
          Practical, affordable environmental habits for real families — no perfection required.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wide text-sage mb-3">Navigate</h3>
        <ul class="flex flex-col gap-2 text-sm">
          <li><a href="/" class="text-cream hover:text-sage transition-colors">Home</a></li>
          <li><a href="/articles" class="text-cream hover:text-sage transition-colors">Articles</a></li>
          <li><a href="/about" class="text-cream hover:text-sage transition-colors">About</a></li>
          <li><a href="/disclosure" class="text-cream hover:text-sage transition-colors">Affiliate Disclosure</a></li>
          <li><a href="/privacy" class="text-cream hover:text-sage transition-colors">Privacy Policy</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wide text-sage mb-3">Follow Us</h3>
        <ul class="flex flex-col gap-2 text-sm">
          <li>
            <a href="https://instagram.com/agreenfamily" target="_blank" rel="noopener" class="text-cream hover:text-sage transition-colors">
              Instagram @agreenfamily
            </a>
          </li>
          <li>
            <a href="https://twitter.com/agreenfamily" target="_blank" rel="noopener" class="text-cream hover:text-sage transition-colors">
              X (Twitter) @agreenfamily
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-leaf pt-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-sage">
      <p>© {year} A Green Family. All rights reserved.</p>
      <p>
        This site contains affiliate links to Amazon, Walmart, and Target.
        <a href="/disclosure" class="underline hover:text-cream">Disclosure</a> · <a href="/privacy" class="underline hover:text-cream">Privacy</a>
      </p>
    </div>

  </div>
</footer>
