---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all unique tags
const allTags = [...new Set(allArticles.flatMap(a => a.data.tags))].sort();

// Filter by tag if ?tag= param is set
const url = Astro.url;
const selectedTag = url.searchParams.get('tag') ?? '';

const filteredArticles = selectedTag
  ? allArticles.filter(a => a.data.tags.includes(selectedTag))
  : allArticles;
---

<Layout
  title="All Articles"
  description="Browse all our practical guides, tips, and product recommendations for eco-friendly family living."
>
  <section class="max-w-5xl mx-auto px-6 py-12">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="font-serif text-4xl text-forest mb-3">All Articles</h1>
      <p class="text-ink-muted text-lg">
        {filteredArticles.length} article{filteredArticles.length !== 1 ? 's' : ''}
        {selectedTag && <span> tagged <strong class="text-leaf">#{selectedTag}</strong></span>}
      </p>
    </div>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        <a
          href="/articles"
          class={`tag ${!selectedTag ? 'bg-leaf text-white' : ''}`}
        >
          All
        </a>
        {allTags.map(tag => (
          <a
            href={`/articles?tag=${tag}`}
            class={`tag ${selectedTag === tag ? 'bg-leaf text-white' : ''}`}
          >
            {tag}
          </a>
        ))}
      </div>
    )}

    <!-- Article grid -->
    {filteredArticles.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredArticles.map(article => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            date={article.data.date}
            tags={article.data.tags}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
            featured={article.data.featured}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-ink-muted">
        <p class="text-4xl mb-4">🌿</p>
        <p>No articles found for this tag.</p>
        <a href="/articles" class="text-leaf hover:text-forest font-medium mt-2 inline-block">Browse all articles</a>
      </div>
    )}

  </section>
</Layout>
