---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all unique tags
const allTags = [...new Set(allArticles.flatMap(a => a.data.tags))].sort();
---

<Layout
  title="All Articles"
  description="Browse all our practical guides, tips, and product recommendations for eco-friendly family living."
>
  <section class="max-w-5xl mx-auto px-6 py-12">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="font-serif text-4xl text-forest mb-3">All Articles</h1>
      <p id="article-count" class="text-ink-muted text-lg">{allArticles.length} articles</p>
    </div>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
        <button
          data-tag=""
          class="tag active-tag"
        >
          All
        </button>
        {allTags.map(tag => (
          <button
            data-tag={tag}
            class="tag"
          >
            {tag}
          </button>
        ))}
      </div>
    )}

    <!-- Article grid -->
    <div id="article-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {allArticles.map(article => (
        <div class="article-card-wrapper" data-tags={article.data.tags.join(',')}>
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            date={article.data.date}
            tags={article.data.tags}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
            featured={article.data.featured}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-20 text-ink-muted">
      <p class="text-4xl mb-4">🌿</p>
      <p>No articles found for this tag.</p>
      <button data-tag="" class="text-leaf hover:text-forest font-medium mt-2 inline-block" id="clear-filter">Browse all articles</button>
    </div>

  </section>
</Layout>

<style>
  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    background-color: #E8F4EA;
    color: #4A7C59;
    border: none;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
  }
  .tag:hover {
    background-color: #4A7C59;
    color: white;
  }
  .active-tag {
    background-color: #4A7C59 !important;
    color: white !important;
  }
</style>

<script define:vars={{ totalCount: allArticles.length }}>

  function filterArticles(selectedTag) {
    const cards = document.querySelectorAll('.article-card-wrapper');
    const grid = document.getElementById('article-grid');
    const emptyState = document.getElementById('empty-state');
    const countEl = document.getElementById('article-count');

    let visible = 0;
    cards.forEach(card => {
      const tags = card.dataset.tags?.split(',') ?? [];
      const show = !selectedTag || tags.includes(selectedTag);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Update count text
    if (selectedTag) {
      countEl.innerHTML = `${visible} article${visible !== 1 ? 's' : ''} tagged <strong style="color:#4A7C59">#${selectedTag}</strong>`;
    } else {
      countEl.textContent = `${totalCount} articles`;
    }

    // Show/hide empty state
    if (visible === 0) {
      grid.style.display = 'none';
      emptyState.classList.remove('hidden');
    } else {
      grid.style.display = '';
      emptyState.classList.add('hidden');
    }

    // Update active tag button
    document.querySelectorAll<HTMLElement>('[data-tag]').forEach(btn => {
      if (btn.dataset.tag === selectedTag) {
        btn.classList.add('active-tag');
      } else {
        btn.classList.remove('active-tag');
      }
    });
  }

  // Wire up all tag buttons
  document.querySelectorAll('[data-tag]').forEach(btn => {
    btn.addEventListener('click', () => {
      filterArticles(btn.dataset.tag || '');
    });
  });
</script>
