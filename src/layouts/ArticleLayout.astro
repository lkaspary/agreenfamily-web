---
import Layout from './Layout.astro';
import AffiliateLink from '../components/AffiliateLink.astro';

export interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  tags: string[];
  image?: string;
  imageAlt?: string;
  affiliateProducts?: { name: string; url: string; store: 'amazon' | 'walmart' }[];
}

const { title, description, date, author, tags, image, imageAlt, affiliateProducts } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={description} image={image} type="article">
  <article class="max-w-3xl mx-auto px-6 py-12">

    <!-- Affiliate disclosure notice -->
    <div class="mb-6 text-xs text-ink-muted bg-sky border border-sage rounded-lg px-4 py-3">
      <strong class="text-forest">Disclosure:</strong> This post may contain affiliate links to Amazon and Walmart.
      If you purchase through these links we earn a small commission at no extra cost to you.
      <a href="/disclosure" class="underline hover:text-forest">Learn more.</a>
    </div>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map(tag => (
          <a href={`/articles?tag=${tag}`} class="tag">{tag}</a>
        ))}
      </div>
      <h1 class="font-serif text-3xl md:text-4xl text-forest leading-tight mb-4">{title}</h1>
      <p class="text-lg text-ink-muted mb-6">{description}</p>
      <div class="flex items-center gap-3 text-sm text-ink-muted border-t border-stone pt-4">
        <span>By <strong class="text-ink">{author}</strong></span>
        <span class="text-stone">·</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    <!-- Featured image -->
    {image && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img src={image} alt={imageAlt ?? title} class="w-full h-72 object-cover" />
      </div>
    )}

    <!-- Article body -->
    <div class="prose prose-green prose-lg max-w-none">
      <slot />
    </div>

    <!-- Affiliate product recommendations -->
    {affiliateProducts && affiliateProducts.length > 0 && (
      <div class="mt-12 p-6 bg-sky rounded-xl border border-sage">
        <h2 class="font-serif text-xl text-forest mb-4">Products Mentioned in This Article</h2>
        <div class="flex flex-col gap-3">
          {affiliateProducts.map(product => (
            <AffiliateLink name={product.name} url={product.url} store={product.store} />
          ))}
        </div>
      </div>
    )}

    <!-- Back link -->
    <div class="mt-10 pt-6 border-t border-stone">
      <a href="/articles" class="text-leaf hover:text-forest font-medium">← Back to all articles</a>
    </div>

  </article>
</Layout>
